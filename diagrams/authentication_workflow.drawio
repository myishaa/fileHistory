        </mxCell>
        <mxCell id="e-scope-db" value="loadAuthUser" style="endArrow=block;html=1;rounded=0;strokeColor=#9333EA;fontSize=12;" edge="1" parent="1" source="scope" target="postgres">
          <mxGeometry relative="1" as="geometry" />
