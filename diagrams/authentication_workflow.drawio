          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-hash-db" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#9333EA;" edge="1" parent="1" source="hash-store" target="postgres">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
